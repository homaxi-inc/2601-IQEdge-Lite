{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iqedge.io/schemas/g2/energy/telemetry/v1",
  "title": "G2 Energy Telemetry v1",
  "description": "MQTT payload for iqedge/g2/{env}/energy/telemetry. Canonical contract for ingest Lambda, Timestream, and Fleet API adapters. Legacy flat fields retained for 007 migration; prefer measures.* SI suffixes.",
  "type": "object",
  "allOf": [
    { "$ref": "https://iqedge.io/schemas/g2/common/g2-envelope/v1" },
    {
      "type": "object",
      "properties": {
        "schema_version": { "const": "energy.telemetry.v1" },
        "domain": { "const": "energy" },
        "system_type": {
          "type": "string",
          "enum": ["iqwatch", "solar_iqbox", "ac_iqbox", "iqtrailer"],
          "description": "Optional on-wire hint; authoritative value is Registry"
        },
        "status": {
          "type": "string",
          "enum": ["running", "stopped", "fault", "unknown"],
          "description": "Overall energy subsystem run state"
        },
        "state": {
          "type": "string",
          "enum": ["NORMAL", "LOW_POWER", "SURVIVAL", "FAULT", "UNKNOWN"],
          "description": "Edge energy state machine (007-defined; extensible)"
        },
        "data_stale": {
          "type": "boolean",
          "description": "True when MPPT/Cerbo data older than freshness threshold"
        },
        "reporting_mode": {
          "type": "string",
          "enum": ["NORMAL", "REDUCED", "SURVIVAL", "RECONCILIATION"],
          "description": "Telemetry cadence / power policy"
        },
        "firmware_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32,
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(\\.[0-9]+)?$",
          "description": "Device-reported firmware (ADR-008). G2 Timestream requires >= v2.3.0 when Registry track=g2. Same field as Legacy device/status."
        },
        "is_reconciliation": {
          "type": "boolean",
          "description": "True for post-reconnect bulk reconcile burst"
        },
        "measures": {
          "type": "object",
          "description": "G2 canonical measures (SI units in field names). Preferred for new firmware.",
          "properties": {
            "battery": {
              "type": "object",
              "properties": {
                "voltage_v": { "type": "number" },
                "current_a": { "type": "number" },
                "soc_pct": { "type": "number", "minimum": 0, "maximum": 100 },
                "charge_state": { "type": "string" },
                "charge_state_code": { "type": "integer", "minimum": 0 }
              },
              "additionalProperties": false
            },
            "solar": {
              "type": "object",
              "properties": {
                "voltage_v": { "type": "number" },
                "current_a": { "type": "number" },
                "power_w": { "type": "number", "minimum": 0 }
              },
              "additionalProperties": false
            },
            "load": {
              "type": "object",
              "properties": {
                "voltage_v": { "type": "number" },
                "current_a": { "type": "number" },
                "power_w": { "type": "number", "minimum": 0 },
                "status": { "type": "string", "enum": ["ON", "OFF", "UNKNOWN"] }
              },
              "additionalProperties": false
            },
            "yield": {
              "type": "object",
              "description": "Energy yield in kWh (G2 correct scale — do not double-divide in ingest)",
              "properties": {
                "total_kwh": { "type": "number", "minimum": 0 },
                "today_kwh": { "type": "number", "minimum": 0 },
                "yesterday_kwh": { "type": "number", "minimum": 0 },
                "month_kwh": { "type": "number", "minimum": 0 },
                "max_power_w": { "type": "number", "minimum": 0 },
                "days_running": { "type": "integer", "minimum": 0 },
                "avg_daily_kwh": { "type": "number", "minimum": 0 },
                "today_vs_yesterday_pct": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "soc": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Legacy flat: state of charge %"
        },
        "battery_voltage": {
          "type": "number",
          "description": "Legacy flat: battery voltage (V)"
        },
        "solar_power": {
          "type": "number",
          "minimum": 0,
          "description": "Legacy flat: solar power (W)"
        },
        "load_power": {
          "type": "number",
          "minimum": 0,
          "description": "Legacy flat: load power (W)"
        },
        "total_yield_kwh": {
          "type": "number",
          "minimum": 0,
          "description": "Legacy flat: cumulative yield (kWh)"
        },
        "today_yield_kwh": {
          "type": "number",
          "minimum": 0,
          "description": "Legacy flat: today yield (kWh)"
        },
        "days_running": {
          "type": "integer",
          "minimum": 0,
          "description": "Legacy flat: days since install"
        },
        "battery": {
          "type": "object",
          "description": "Legacy nested block (payload.md v1/v2)",
          "properties": {
            "voltage": { "type": "number" },
            "current": { "type": "number" },
            "soc": { "type": "number", "minimum": 0, "maximum": 100 },
            "charge_state": { "type": "string" },
            "charge_state_code": { "type": "integer" }
          },
          "additionalProperties": true
        },
        "solar": {
          "type": "object",
          "properties": {
            "voltage": { "type": "number" },
            "current": { "type": "number" },
            "power": { "type": "number" }
          },
          "additionalProperties": true
        },
        "load": {
          "type": "object",
          "properties": {
            "voltage": { "type": "number" },
            "current": { "type": "number" },
            "power": { "type": "number" },
            "status": { "type": "string" }
          },
          "additionalProperties": true
        },
        "history": {
          "type": "object",
          "description": "Legacy nested yield block",
          "properties": {
            "total_yield_kwh": { "type": "number" },
            "today_yield_kwh": { "type": "number" },
            "yesterday_yield_kwh": { "type": "number" },
            "month_yield_kwh": { "type": "number" },
            "max_power_w": { "type": "number" },
            "days_running": { "type": "integer" },
            "avg_daily_yield_kwh": { "type": "number" },
            "today_vs_yesterday_pct": { "type": "number" }
          },
          "additionalProperties": true
        },
        "system": {
          "type": "object",
          "description": "Legacy device block; serial should match component_id for MPPT role",
          "properties": {
            "serial": { "type": "string" },
            "temp": { "type": "number" },
            "output": { "type": "number" },
            "pid": { "type": "string" },
            "firmware": { "type": "string" }
          },
          "additionalProperties": true
        },
        "legacy": {
          "type": "object",
          "description": "Deprecated aliases for Legacy SaveDeviceStatus mapping",
          "properties": {
            "deviceId": {
              "type": "string",
              "description": "MPPT SER# — same as component_id when role=mppt"
            },
            "device": { "type": "string", "const": "IQEdge" }
          },
          "additionalProperties": false
        }
      },
      "required": ["status", "data_stale", "reporting_mode"],
      "anyOf": [
        {
          "required": ["measures"],
          "properties": {
            "measures": {
              "type": "object",
              "required": ["battery"],
              "properties": {
                "battery": {
                  "type": "object",
                  "required": ["soc_pct"]
                }
              }
            }
          }
        },
        {
          "required": ["soc", "battery_voltage"]
        }
      ]
    }
  ]
}
