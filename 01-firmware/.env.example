# Agent 007 — AWS Telemetry Verification (copy to .env, never commit .env)
# IAM user: Agent-007-Telemetry-Verifier (read-only per SOP)

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# HIL / field device identifiers (replace with your test units)
# MPPT DynamoDB/Timestream key — often MPPT serial or cloud deviceId
TEST_MPPT_DEVICE_ID=HQ2513NH99U
# MPPT serial from VE.Direct SER# (= deviceId in DeviceLatestStatus)
TEST_MPPT_SERIAL=HQ2513NH99U
# RUT router serial (serial_input4)
TEST_RUT_SN=

# Egress API keys (API Gateway 1y9689tax0 — copy real value into .env only)
IQWATCH_API_KEY=
RUT_API_KEY=
